# out-type: tyir
# rule: symbolic_function_availability_signatures
TyFnDecl source() -> runtime num [runtime-authority: source-boundary] [availability-signature: params=[], result=RT, internal-rt=runtime function boundary]
TyFnDecl increment(value: num) -> num [runtime-authority: none] [availability-signature: params=[param0], result=param0]
TyFnDecl add(a: num, b: num) -> num [runtime-authority: none] [availability-signature: params=[param0, param1], result=(param0 | param1)]
TyFnDecl first(a: num, b: num) -> num [runtime-authority: none] [availability-signature: params=[param0, param1], result=(param0 | param1)]
TyCall(add): runtime num [availability: runtime]
TyCall(increment): runtime num [availability: runtime]
TyCall(first): runtime num [availability: runtime]
